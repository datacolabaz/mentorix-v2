DATABASE_URL=postgresql://user:password@host:5432/mentorix
JWT_SECRET=your_super_secret_key
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://frontend.example
FRONTEND_BASE_URL=https://mentorix.example
SMS_LOGIN=your_sendsms_login
SMS_PASSWORD=your_sendsms_password
SMS_TITLE=Mentorix

# Payriff (plan ödənişi) — merchant panelindən secret; Authorization header kimi göndərilir
PAYRIFF_SECRET_KEY=
# PAYRIFF_API_SECRET və ya PAYRIFF_KEY alternativ adlardır (biri kifayətdir)
# PAYRIFF_BASE_URL=https://api.payriff.com/api/v3
# PAYRIFF_CALLBACK_URL=https://api.example.com/api/billing/payriff/return
# PAYRIFF_CALLBACK_TOKEN=təsadüfi_uzun_string
# PAYRIFF_PRORATION=1
