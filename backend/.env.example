# Lokal: öz PostgreSQL URL-iniz və ya Railway → Postgres → Variables → DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mentorix
JWT_SECRET=your_super_secret_key
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://frontend.example
FRONTEND_BASE_URL=https://mentorix.example
SMS_LOGIN=your_sendsms_login
SMS_PASSWORD=your_sendsms_password
SMS_TITLE=Mentorix

# Resend — email verification (signup)
# Create a verified sender address in Resend and set it here.
RESEND_API_KEY=
VERIFY_EMAIL_FROM=notifications@mentorix.az
# Optional: where the verification link points.
# Default uses FRONTEND_BASE_URL (or FRONTEND_URL) + /verify-email?token=...
EMAIL_VERIFICATION_BASE_URL=
EMAIL_VERIFICATION_TTL_MINUTES=60

# WhatsApp Cloud API (Meta) — konfiqurasiya olunmayıbsa bildirişlər SMS ilə gedir
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v25.0
#
# Prod (recipient siyahısı OLMADAN): WhatsApp Manager-də təsdiqlənmiş şablon adı
# Kütləvi bildiriş üçün məs: body = "Mentorix: {{1}}"
# WHATSAPP_TEMPLATE_NAME=mentorix_bildiris
# WHATSAPP_TEMPLATE_LANGUAGE=en_US
#
# İmtahan bildirişi (4 parametr: ad, imtahan, tarix, dəqiqə) — opsional, yoxdursa ümumi şablon
# WHATSAPP_EXAM_TEMPLATE_NAME=mentorix_exam

# Payriff (plan ödənişi) — merchant panelindən secret; Authorization header kimi göndərilir
PAYRIFF_SECRET_KEY=
# Applications səhifəsindəki Merchant ID (ES...); create order üçün lazımdır
PAYRIFF_MERCHANT_ID=
# PAYRIFF_API_SECRET və ya PAYRIFF_KEY alternativ adlardır (biri kifayətdir)
# PAYRIFF_BASE_URL=https://api.payriff.com/api/v3
# PAYRIFF_CALLBACK_URL=https://api.example.com/api/billing/payriff/return
# PAYRIFF_CALLBACK_TOKEN=təsadüfi_uzun_string
# PAYRIFF_PRORATION=1

# OpenAI — tapşırıq AI köməkçi (müəllim panelində «AI təklifi»)
OPENAI_API_KEY=
# OPENAI_ASSIGNMENT_MODEL=gpt-4o-mini
# OPENAI_UNIVERSITY_SCRAPER_MODEL=gpt-4o-mini
# UNIVERSITY_SCRAPER_AUTO_APPROVE=false
# UNIVERSITY_SCRAPER_BATCH_LIMIT=3

# Tələbəyə yeni tapşırıq e-poçtu (Resend — VERIFY_EMAIL_FROM ilə eyni göndərən)
# RESEND_API_KEY= artıq yuxarıda
# FRONTEND_BASE_URL=https://edupanel.az
